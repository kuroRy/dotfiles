{
  "title": "Right Command to Hyper Key",
  "rules": [
    {
      "description": "Right Command -> Hyper (ctrl+alt+cmd+shift)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_command",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_shift",
              "modifiers": [
                "left_control",
                "left_option",
                "left_command"
              ]
            }
          ]
        }
      ]
    }
  ]
}
